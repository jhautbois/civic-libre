# Configuration de l'instance Civic Libre.
# Copier ce fichier en .env puis adapter les valeurs à la commune.
# Toutes les variables ont un défaut de démonstration : sans .env,
# `docker compose up` lance une instance locale complète.

# Domaines (en production : votre domaine réel, DNS pointant vers le serveur)
CIVIC_DOMAIN=civic.localhost
CIVIC_AGENDA_DOMAIN=agenda.civic.localhost

# Identité de la commune
CIVIC_COMMUNE_NAME=Villebourg
# Teinte d'accent : le système dérive automatiquement des variantes
# conformes RGAA, la couleur brute n'est jamais utilisée telle quelle.
CIVIC_ACCENT_COLOR=#31597F

# Mode debug : JAMAIS 1 en production.
CIVIC_DEBUG=0

# Clé secrète Django : générée et persistée automatiquement si absente.
# CIVIC_SECRET_KEY=

# Courriel transactionnel. En démo : MailHog (http://localhost:8025).
# En production : relais SMTP France/UE avec SPF et DKIM configurés
# (voir docs/exploitation/installation.md, prérequis).
CIVIC_SMTP_HOST=mailhog
CIVIC_SMTP_PORT=1025
CIVIC_SMTP_USER=
CIVIC_SMTP_PASSWORD=
CIVIC_SMTP_TLS=0
CIVIC_SMTP_FROM=mairie@civic.localhost

# Adresse de l'exploitant technique : reçoit les alertes (sauvegardes,
# tâches en échec). Vide = alertes désactivées (déconseillé en production).
CIVIC_OPERATOR_EMAIL=

# Géocodage (Base Adresse Nationale via la Géoplateforme IGN, 50 req/s).
CIVIC_GEOCODING_URL=https://data.geopf.fr/geocodage

# Fond de carte : URL gabarit de tuiles, relayée et mise en cache par
# le cœur (l'IP des habitants ne part pas chez le fournisseur).
CIVIC_TILES_URL=https://a.tile.openstreetmap.fr/osmfr/{z}/{x}/{y}.png

# Centre de la carte de signalement (coordonnées du bourg) et zoom.
CIVIC_CENTER_LAT=47.3900
CIVIC_CENTER_LON=0.6889
CIVIC_CENTER_ZOOM=15
